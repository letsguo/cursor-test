PORT=3000
# For backend server deployment (Render/Railway/Fly/etc):
# Comma-separated list of allowed frontend origins (or "*" for open CORS).
CORS_ORIGINS=https://your-vercel-frontend.vercel.app,http://localhost:3000

# Optional: for static frontend host if you want to inject at runtime.
# If blank, client uses same-origin or stored value from host screen.
GTM_SOCKET_URL=
